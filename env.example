# ─────────────────────────────────────────────
#  NBFC AI Platform — Environment Variables
# ─────────────────────────────────────────────

# Required: Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required: Railway PostgreSQL connection URL
# Available automatically when you add a PostgreSQL service in Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required: Random secret for signing session cookies
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_long_random_secret_here

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Railway sets this automatically — don't set manually
# PORT=8000
